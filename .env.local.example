# Shopify Storefront API Configuration
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=your-storefront-access-token

# Shopify Admin API (server-side only)
SHOPIFY_ADMIN_ACCESS_TOKEN=your-admin-api-token

# Google Tag Manager (get from tagmanager.google.com)
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Google Analytics 4 (get from analytics.google.com)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Note: Get Shopify credentials from Admin > Settings > Apps and sales channels > Develop apps
